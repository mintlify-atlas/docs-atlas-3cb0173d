  "keyFeatures": [
    "Raycasting 3D rendering engine",
    "Multi-threaded rendering with configurable camera threads",
    "SDL2-based graphics and audio system",
    "Custom map format (.cub) with entity system",
    "Player and enemy AI with pathfinding",
    "Weapon and collectible system",
    "Door and elevator mechanics",
    "Controller support (Xbox, PlayStation)",
    "Web support via Emscripten/WebAssembly",
    "Minimap and HUD system"
  ],
