    "wall_new() - Create wall entity",
    "door_new_e() - Create door entity",
    "elevator_new() - Create elevator entity",
    "item_new() - Create item instance",
    "weapon_new() - Create weapon instance",
    "collectible_new() - Create collectible instance",
    "drop_new() - Create drop entity",
    "render_game() - Render game frame",
    "sprite_new() - Create animated sprite",
    "get_sprite_image() - Get current sprite frame",
    "get_sprite3d_image() - Get 3D sprite from angle"
